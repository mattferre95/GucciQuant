# GUCCI QUANT — Environment Config
# cp .env.template .env then fill in values

# Hyperliquid (create a FRESH wallet for bot only)
HYPERLIQUID_PRIVATE_KEY=0x_your_64char_hex_private_key
HYPERLIQUID_WALLET_ADDRESS=0x_your_wallet_address

# AI (optional — for RBI strategy engine)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Discord (recommended — paste webhook URL from channel settings → Integrations)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Telegram (optional — only needed for /commands like /stop /status)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_personal_chat_id

# Safety — START HERE, never change until ready
TRADING_ENABLED=false   # true = live trading on
PAPER_MODE=true         # false = real money
STARTING_CAPITAL=67     # your actual USDC balance (67.70 USDC in Perps as of May 2026)

# Risk limits
MAX_CAPITAL_DEPLOYED=80  # % of capital to deploy
DAILY_LOSS_LIMIT=5       # pause if -$5/day
MAX_POSITIONS=3          # max simultaneous trades
DB_PATH=data/gucci_quant.db
